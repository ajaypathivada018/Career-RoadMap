# Career Sync API — environment variable contract
# This file is COMMITTED. It must contain placeholders only — never real keys.
# Copy this file to `apps/api/.env` and fill in real values there (apps/api/.env is gitignored).

# Core
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/CareerOs?retryWrites=true&w=majority

# JWT — must be a long random string in production. Server refuses to start with the default in production.
JWT_SECRET=change-me-to-a-long-random-string-in-production

# CORS: comma-separated allowed origins (e.g. https://careersync.vercel.app)
# Localhost dev origins (3000, 3002) are always allowed.
CORS_ORIGINS=

# Google Gemini API — used by roadmaps + skill evaluator + AI proxy endpoints
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API — used by Next.js /api/generate-course route (server-side)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# YouTube Data API v3 — used by course generator for video lookups
YOUTUBE_API_KEY=your_youtube_api_key_here

# RapidAPI (JSearch) — used by POST /api/roadmaps/jobs-search
RAPIDAPI_KEY=your_rapidapi_key_here

# EmailJS (OTP delivery for /api/auth/request-otp + /reset-password + /login-otp)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_GMAIL=your_emailjs_sender_email

